{
  "name": "ecaasia_mmo",
  "version": "1.0.0",
  "description": "Text based MMO RPG",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "dev": "nodemon",
    "cli": "tsx src/cli.ts",
    "seed": "tsx src/seed.ts",
    "server": "tsx src/server.ts",
    "typeorm-mig": "tsx ./node_modules/typeorm/cli.js migration:generate -d ./src/data-source.ts ./src/migration/",
    "typeorm-run": "tsx ./node_modules/typeorm/cli.js migration:run -d ./src/data-source.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlmiranteFuchs/ecaasia_mmo.git"
  },
  "keywords": [
    "MMO_RPG"
  ],
  "author": "Almirante Fuchs",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AlmiranteFuchs/ecaasia_mmo/issues"
  },
  "homepage": "https://github.com/AlmiranteFuchs/ecaasia_mmo#readme",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@types/lodash": "^4.14.186",
    "baileys": "^6.7.23",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "jimp": "^1.6.1",
    "link-preview-js": "^3.2.0",
    "lodash": "^4.17.21",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20",
    "typescript": "^4.7.4"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.45",
    "jest": "^30.4.2",
    "nodemon": "^2.0.19",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.17.0"
  }
}
